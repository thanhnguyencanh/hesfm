<?xml version="1.0"?>
<!--
  hesfm_exploration.launch
  Launch file for HESFM with autonomous exploration
  
  Extends the base HESFM system with:
  - EMI-based exploration planner
  - Integration with move_base for navigation
  - Frontier visualization
  
  Usage:
    roslaunch hesfm hesfm_exploration.launch
    roslaunch hesfm hesfm_exploration.launch auto_navigate:=true
  
  Author: Thanh Nguyen Canh <thanhnc@jaist.ac.jp>
  Date: 2026
-->
<launch>
  <!-- ===================================================================== -->
  <!-- Arguments -->
  <!-- ===================================================================== -->
  
  <!-- Base HESFM arguments -->
  <arg name="camera_name" default="camera"/>
  <arg name="map_frame" default="map"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_link"/>
  <arg name="segmentation_backend" default="dformer"/>
  
  <!-- Exploration arguments -->
  <arg name="auto_navigate" default="false"/>
  <arg name="exploration_rate" default="1.0"/>
  <arg name="max_exploration_distance" default="10.0"/>
  <arg name="min_frontier_size" default="10"/>
  
  <!-- Sensor parameters for exploration -->
  <arg name="sensor_range" default="6.0"/>
  <arg name="sensor_fov_horizontal" default="1.2"/>  <!-- ~69 degrees -->
  <arg name="sensor_fov_vertical" default="0.9"/>    <!-- ~52 degrees -->
  
  <!-- Safety -->
  <arg name="min_obstacle_distance" default="0.5"/>
  
  <!-- Navigation -->
  <arg name="use_move_base" default="true"/>
  
  <!-- Visualization -->
  <arg name="rviz" default="true"/>
  
  <!-- ===================================================================== -->
  <!-- Base HESFM System -->
  <!-- ===================================================================== -->
  
  <include file="$(find hesfm)/launch/hesfm.launch">
    <arg name="camera_name" value="$(arg camera_name)"/>
    <arg name="map_frame" value="$(arg map_frame)"/>
    <arg name="segmentation_backend" value="$(arg segmentation_backend)"/>
    <arg name="launch_camera" value="true"/>
    <arg name="launch_segmentation" value="true"/>
    <arg name="launch_mapper" value="true"/>
    <arg name="launch_costmap" value="true"/>
    <arg name="launch_visualization" value="true"/>
    <arg name="rviz" value="false"/>  <!-- We'll launch our own RViz -->
  </include>
  
  <!-- ===================================================================== -->
  <!-- Exploration Node -->
  <!-- ===================================================================== -->
  
  <node name="exploration_node" pkg="hesfm" type="exploration_node"
        output="screen" respawn="false">
    <!-- Frame IDs -->
    <param name="map_frame" value="$(arg map_frame)"/>
    <param name="robot_frame" value="$(arg base_frame)"/>
    
    <!-- Exploration parameters -->
    <param name="update_rate" value="$(arg exploration_rate)"/>
    <param name="max_distance" value="$(arg max_exploration_distance)"/>
    <param name="min_frontier_size" value="$(arg min_frontier_size)"/>
    <param name="auto_navigate" value="$(arg auto_navigate)"/>
    
    <!-- Sensor parameters -->
    <param name="sensor_range" value="$(arg sensor_range)"/>
    <param name="sensor_fov_horizontal" value="$(arg sensor_fov_horizontal)"/>
    <param name="sensor_fov_vertical" value="$(arg sensor_fov_vertical)"/>
    
    <!-- Safety -->
    <param name="min_obstacle_distance" value="$(arg min_obstacle_distance)"/>
    
    <!-- Utility weights -->
    <param name="weight_info_gain" value="1.0"/>
    <param name="weight_distance" value="0.3"/>
    <param name="weight_uncertainty" value="0.5"/>
    
    <!-- EMI parameters -->
    <param name="min_info_gain" value="0.1"/>
    <param name="max_goals" value="10"/>
  </node>
  
  <!-- ===================================================================== -->
  <!-- Move Base (optional) -->
  <!-- ===================================================================== -->
  
  <group if="$(arg use_move_base)">
    <!-- Remap costmap to move_base -->
    <remap from="/move_base/global_costmap/costmap" to="/costmap"/>
    <remap from="/move_base/local_costmap/costmap" to="/costmap"/>
    
    <!-- Goal relay from exploration to move_base -->
    <node name="exploration_goal_relay" pkg="hesfm" type="exploration_goal_relay.py"
          output="screen" if="$(arg auto_navigate)">
      <remap from="exploration_goal" to="exploration_node/exploration_goal"/>
      <remap from="move_base_goal" to="/move_base_simple/goal"/>
      <param name="goal_tolerance" value="0.5"/>
      <param name="replan_interval" value="10.0"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- RViz with exploration config -->
  <!-- ===================================================================== -->
  
  <group if="$(arg rviz)">
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find hesfm)/rviz/hesfm_exploration.rviz"
          output="screen"/>
  </group>
  
</launch>
