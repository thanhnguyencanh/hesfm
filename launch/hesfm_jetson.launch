<?xml version="1.0"?>
<!--
  hesfm_jetson.launch
  Optimized launch file for NVIDIA Jetson Xavier AGX deployment
  
  Features:
  - ESANet with TensorRT FP16 for real-time inference
  - Optimized resolution and downsampling
  - Reduced map update frequency
  - Memory-efficient settings
  
  Target: >10 Hz semantic mapping on Jetson Xavier AGX
  
  Usage:
    roslaunch hesfm hesfm_jetson.launch
  
  Author: Thanh Nguyen Canh <thanhnc@jaist.ac.jp>
  Date: 2026
-->
<launch>
  <!-- ===================================================================== -->
  <!-- Arguments -->
  <!-- ===================================================================== -->
  
  <!-- Camera -->
  <arg name="camera_name" default="camera"/>
  <arg name="serial_no" default=""/>
  
  <!-- Frame IDs -->
  <arg name="map_frame" default="map"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_link"/>
  
  <!-- Resolution (lower for real-time) -->
  <arg name="color_width" default="640"/>
  <arg name="color_height" default="480"/>
  <arg name="depth_width" default="640"/>
  <arg name="depth_height" default="480"/>
  <arg name="fps" default="30"/>
  
  <!-- Processing (aggressive downsampling for speed) -->
  <arg name="downsample_factor" default="4"/>
  <arg name="map_resolution" default="0.08"/>

  <!-- Processing options -->
  <arg name="num_classes" default="37"/>

  <!-- Segmentation backend: dformer, esanet_trt, esanet_pytorch -->
  <arg name="segmentation_backend" default="esanet_trt"/>

  
  <!-- TensorRT engine path -->
  <arg name="trt_engine" default="$(find hesfm)/models/esanet_r34_sunrgbd_fp16.engine"/>
  <arg name="esanet_dataset" default="sunrgbd"/>
  
  <!-- Features -->
  <arg name="launch_exploration" default="false"/>
  <arg name="launch_segmentation" default="true"/>
  <arg name="semantic_cloud" default="true"/>
  <arg name="launch_mapper" default="false"/>
  <arg name="rviz" default="true"/>
  
  <!-- ===================================================================== -->
  <!-- Intel RealSense D455 (optimized settings) -->
  <!-- ===================================================================== -->
  
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="$(arg camera_name)"/>
    <arg name="serial_no" value="$(arg serial_no)"/>
    
    <!-- Reduced resolution for Jetson -->
    <arg name="color_width" value="$(arg color_width)"/>
    <arg name="color_height" value="$(arg color_height)"/>
    <arg name="color_fps" value="$(arg fps)"/>
    <arg name="depth_width" value="$(arg depth_width)"/>
    <arg name="depth_height" value="$(arg depth_height)"/>
    <arg name="depth_fps" value="$(arg fps)"/>
    
    <!-- Minimal streams -->
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="enable_infra1" value="false"/>
    <arg name="enable_infra2" value="false"/>
    <arg name="enable_pointcloud" value="false"/>
    <arg name="enable_gyro" value="false"/>
    <arg name="enable_accel" value="false"/>
    
    <!-- Alignment -->
    <arg name="align_depth" value="true"/>
    
    <!-- Minimal filtering (done on GPU instead) -->
    <arg name="filters" value=""/>
  </include>
  
  <!-- ===================================================================== -->
  <!-- Semantic Segmentation (TensorRT) -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_segmentation)">
    <node name="semantic_segmentation_node" pkg="hesfm" type="semantic_segmentation_node.py"
          output="screen" respawn="false">
      <!-- Input topics -->
      <remap from="color/image_raw" to="$(arg camera_name)/color/image_raw"/>
      <remap from="depth/image_rect_raw" to="$(arg camera_name)/aligned_depth_to_color/image_raw"/>
      <remap from="color/camera_info" to="$(arg camera_name)/color/camera_info"/>
      
      <!-- Parameters -->
      <param name="backend" value="$(arg segmentation_backend)"/>
      <param name="esanet_dataset" value="$(arg esanet_dataset)"/>
      <param name="num_classes" value="$(arg num_classes)"/>
      <param name="input_height" value="480"/>
      <param name="input_width" value="640"/>
      <param name="confidence_threshold" value="0.3"/>

      <!-- Model paths -->
      <param name="dformer_model_path" value="$(find hesfm)/models/dformer_large_sunrgbd.pth"/>
      <param name="esanet_model_path" value="$(find hesfm)/models/esanet_r34_sunrgbd.pth"/>
      <param name="esanet_trt_engine" value="$(find hesfm)/models/esanet_r34_sunrgbd_fp16.engine"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Semantic Point Cloud (optimized) -->
  <!-- ===================================================================== -->
  
  <group if="$(arg semantic_cloud)">
    <node name="semantic_cloud_node" pkg="hesfm" type="semantic_cloud_node"
          output="screen" respawn="false">
      <!-- Input topics -->
      <remap from="color/image_raw" to="$(arg camera_name)/color/image_raw"/>
      <remap from="depth/image_rect_raw" to="$(arg camera_name)/aligned_depth_to_color/image_raw"/>
      <remap from="color/camera_info" to="$(arg camera_name)/color/camera_info"/>
      <remap from="semantic/image" to="semantic_segmentation_node/semantic_image"/>
      
      <!-- Parameters -->
      <param name="downsample_factor" value="$(arg downsample_factor)"/>
      <param name="min_depth" value="0.1"/>
      <param name="max_depth" value="6.0"/>
      <param name="esanet_dataset" value="$(arg esanet_dataset)"/>
      <param name="default_uncertainty" value="0.3"/>
      <param name="queue_size" value="30"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- HESFM Mapper (optimized) -->
  <!-- ===================================================================== -->
  <group if="$(arg launch_mapper)">
    <node name="hesfm_mapper_node" pkg="hesfm" type="hesfm_mapper_node"
          output="screen" respawn="true">
      <!-- Frame IDs -->
      <param name="map_frame" value="$(arg map_frame)"/>
      
      <!-- Lower resolution map for speed -->
      <param name="resolution" value="$(arg map_resolution)"/>
      <param name="map_size_x" value="15.0"/>
      <param name="map_size_y" value="15.0"/>
      <param name="map_size_z" value="2.5"/>
      <param name="num_classes" value="37"/>
      
      <!-- Reduced primitive count -->
      <param name="target_primitives" value="64"/>
      <param name="min_points_per_primitive" value="10"/>
      
      <!-- Lower publish rates -->
      <param name="map_publish_rate" value="1.0"/>
      <param name="costmap_publish_rate" value="2.0"/>
      
      <!-- Kernel parameters (faster) -->
      <param name="length_scale_min" value="0.15"/>
      <param name="length_scale_max" value="0.4"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Costmap (simplified) -->
  <!-- ===================================================================== -->
  
  <!-- <node name="costmap_node" pkg="hesfm" type="costmap_node"
        output="screen" respawn="true">
    <param name="map_frame" value="$(arg map_frame)"/>
    <param name="resolution" value="$(arg map_resolution)"/>
    <param name="size_x" value="15.0"/>
    <param name="size_y" value="15.0"/>
    <param name="publish_rate" value="2.0"/>
    <param name="inflation_radius" value="0.25"/>
    
    <rosparam param="traversable_classes">[1, 19]</rosparam>
  </node>
   -->
  <!-- ===================================================================== -->
  <!-- Exploration (optional) -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_exploration)">
    <node name="exploration_node" pkg="hesfm" type="exploration_node"
          output="screen" respawn="true">
      <param name="map_frame" value="$(arg map_frame)"/>
      <param name="robot_frame" value="$(arg base_frame)"/>       
      <param name="update_rate" value="0.5"/>  <!-- Lower rate for Jetson -->
      <param name="max_goals" value="5"/>
      <param name="sensor_range" value="4.0"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- RViz (optional, resource intensive) -->
  <!-- ===================================================================== -->
  
  <group if="$(arg rviz)">
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find hesfm)/rviz/hesfm.rviz"
          output="screen"/>
  </group>
  
</launch>
