<?xml version="1.0"?>
<!--
  hesfm_navigation.launch
  Launch file for HESFM with ROS Navigation Stack integration
  
  Provides semantic-aware navigation using:
  - HESFM semantic costmap as global costmap layer
  - Standard local planner with semantic awareness
  - Semantic-based recovery behaviors
  
  Usage:
    roslaunch hesfm hesfm_navigation.launch
    roslaunch hesfm hesfm_navigation.launch robot:=turtlebot3
  
  Author: Thanh Nguyen Canh <thanhnc@jaist.ac.jp>
  Date: 2026
-->
<launch>
  <!-- ===================================================================== -->
  <!-- Arguments -->
  <!-- ===================================================================== -->
  
  <!-- Robot configuration -->
  <arg name="robot" default="generic"/>
  <arg name="robot_radius" default="0.3"/>
  
  <!-- Frame IDs -->
  <arg name="map_frame" default="map"/>
  <arg name="odom_frame" default="odom"/>
  <arg name="base_frame" default="base_link"/>
  
  <!-- HESFM arguments -->
  <arg name="camera_name" default="camera"/>
  <arg name="segmentation_backend" default="dformer"/>
  <arg name="resolution" default="0.05"/>
  
  <!-- Navigation arguments -->
  <arg name="global_planner" default="navfn/NavfnROS"/>
  <arg name="local_planner" default="dwa_local_planner/DWAPlannerROS"/>
  
  <!-- Costmap parameters -->
  <arg name="inflation_radius" default="0.5"/>
  <arg name="cost_scaling_factor" default="10.0"/>
  
  <!-- Visualization -->
  <arg name="rviz" default="true"/>
  
  <!-- ===================================================================== -->
  <!-- Base HESFM System -->
  <!-- ===================================================================== -->
  
  <include file="$(find hesfm)/launch/hesfm.launch">
    <arg name="camera_name" value="$(arg camera_name)"/>
    <arg name="map_frame" value="$(arg map_frame)"/>
    <arg name="segmentation_backend" value="$(arg segmentation_backend)"/>
    <arg name="resolution" value="$(arg resolution)"/>
    <arg name="launch_costmap" value="true"/>
    <arg name="rviz" value="false"/>
  </include>
  
  <!-- ===================================================================== -->
  <!-- Move Base -->
  <!-- ===================================================================== -->
  
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <!-- Global planner -->
    <param name="base_global_planner" value="$(arg global_planner)"/>
    
    <!-- Local planner -->
    <param name="base_local_planner" value="$(arg local_planner)"/>
    
    <!-- Recovery behaviors -->
    <param name="recovery_behavior_enabled" value="true"/>
    <param name="clearing_rotation_allowed" value="true"/>
    
    <!-- Planner frequencies -->
    <param name="planner_frequency" value="1.0"/>
    <param name="controller_frequency" value="10.0"/>
    <param name="planner_patience" value="5.0"/>
    <param name="controller_patience" value="15.0"/>
    
    <!-- Oscillation -->
    <param name="oscillation_timeout" value="10.0"/>
    <param name="oscillation_distance" value="0.2"/>
    
    <!-- ================================================================= -->
    <!-- Global Costmap -->
    <!-- ================================================================= -->
    
    <rosparam ns="global_costmap" subst_value="true">
      global_frame: $(arg map_frame)
      robot_base_frame: $(arg base_frame)
      update_frequency: 2.0
      publish_frequency: 1.0
      static_map: false
      rolling_window: false
      width: 40.0
      height: 40.0
      resolution: $(arg resolution)
      
      transform_tolerance: 0.5
      
      plugins:
        - {name: semantic_layer, type: "costmap_2d::StaticLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}
      
      semantic_layer:
        map_topic: /semantic_costmap
        subscribe_to_updates: true
        track_unknown_space: true
        use_maximum: true
      
      inflation_layer:
        inflation_radius: $(arg inflation_radius)
        cost_scaling_factor: $(arg cost_scaling_factor)
    </rosparam>
    
    <!-- ================================================================= -->
    <!-- Local Costmap -->
    <!-- ================================================================= -->
    
    <rosparam ns="local_costmap" subst_value="true">
      global_frame: $(arg odom_frame)
      robot_base_frame: $(arg base_frame)
      update_frequency: 5.0
      publish_frequency: 2.0
      static_map: false
      rolling_window: true
      width: 6.0
      height: 6.0
      resolution: $(arg resolution)
      
      transform_tolerance: 0.5
      
      plugins:
        - {name: obstacle_layer, type: "costmap_2d::ObstacleLayer"}
        - {name: inflation_layer, type: "costmap_2d::InflationLayer"}
      
      obstacle_layer:
        observation_sources: semantic_cloud
        semantic_cloud:
          sensor_frame: camera_color_optical_frame
          data_type: PointCloud2
          topic: /semantic_cloud
          marking: true
          clearing: true
          min_obstacle_height: 0.1
          max_obstacle_height: 2.0
          obstacle_range: 5.0
          raytrace_range: 6.0
      
      inflation_layer:
        inflation_radius: $(arg inflation_radius)
        cost_scaling_factor: $(arg cost_scaling_factor)
    </rosparam>
    
    <!-- ================================================================= -->
    <!-- DWA Local Planner -->
    <!-- ================================================================= -->
    
    <rosparam ns="DWAPlannerROS" subst_value="true">
      # Robot configuration
      max_vel_x: 0.5
      min_vel_x: -0.1
      max_vel_y: 0.0
      min_vel_y: 0.0
      max_vel_theta: 1.0
      min_vel_theta: -1.0
      
      max_vel_trans: 0.5
      min_vel_trans: 0.1
      
      acc_lim_x: 2.5
      acc_lim_y: 0.0
      acc_lim_theta: 3.2
      
      # Goal tolerance
      xy_goal_tolerance: 0.2
      yaw_goal_tolerance: 0.1
      latch_xy_goal_tolerance: false
      
      # Forward simulation
      sim_time: 1.5
      sim_granularity: 0.025
      vx_samples: 20
      vy_samples: 1
      vth_samples: 40
      
      # Trajectory scoring
      path_distance_bias: 32.0
      goal_distance_bias: 24.0
      occdist_scale: 0.1
      forward_point_distance: 0.325
      stop_time_buffer: 0.2
      scaling_speed: 0.25
      max_scaling_factor: 0.2
      
      # Oscillation prevention
      oscillation_reset_dist: 0.05
    </rosparam>
    
    <!-- ================================================================= -->
    <!-- NavFn Global Planner -->
    <!-- ================================================================= -->
    
    <rosparam ns="NavfnROS">
      allow_unknown: true
      default_tolerance: 0.1
      visualize_potential: false
    </rosparam>
    
  </node>
  
  <!-- ===================================================================== -->
  <!-- RViz -->
  <!-- ===================================================================== -->
  
  <group if="$(arg rviz)">
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find hesfm)/rviz/hesfm_navigation.rviz"
          output="screen"/>
  </group>
  
</launch>
