<?xml version="1.0"?>
<!--
  hesfm.launch
  Main launch file for HESFM semantic mapping system
  
  This launches the complete HESFM pipeline:
  - Intel RealSense D455 camera
  - Semantic segmentation node
  - Semantic point cloud generator
  - HESFM mapper
  - Visualization
  
  Usage:
    roslaunch hesfm hesfm.launch
    roslaunch hesfm hesfm.launch rviz:=true
    roslaunch hesfm hesfm.launch segmentation_backend:=esanet_trt
  
  Author: Thanh Nguyen Canh <thanhnc@jaist.ac.jp>
  Date: 2026
-->
<launch>
  <!-- ===================================================================== -->
  <!-- Arguments -->
  <!-- ===================================================================== -->
  
  <!-- Device and frame arguments -->
  <arg name="camera_name" default="camera"/>
  <arg name="serial_no" default=""/>
  <arg name="map_frame" default="global"/>
  <arg name="odom_frame" default="imu"/>
  <arg name="base_frame" default="camera_link"/>
  
  <!-- Segmentation backend: dformer, esanet_trt, esanet_pytorch -->
  <arg name="segmentation_backend" default="esanet_trt"/>

  <!-- ESANet dataset: 'nyuv2' (40 classes) or 'sunrgbd' (37 classes) -->
  <arg name="esanet_dataset" default="sunrgbd"/>

  <!-- Processing options -->
  <arg name="downsample_factor" default="2"/>
  <arg name="num_classes" default="37"/>
  
  <!-- Map parameters -->     
  <arg name="resolution" default="0.05"/>
  <arg name="map_size_x" default="20.0"/>
  <arg name="map_size_y" default="20.0"/>
  <arg name="map_size_z" default="3.0"/>
  
  <!-- Feature toggles -->
  <arg name="launch_camera" default="true"/>
  <arg name="launch_segmentation" default="false"/>
  <arg name="launch_mapper" default="false"/>
  <arg name="launch_costmap" default="false"/>
  <arg name="launch_visualization" default="false"/>
  <arg name="rviz" default="true"/>
  <arg name="launch_costmap_3d" default="false"/>

  <!-- OpenVINS VIO (ov_msckf) -->
  <arg name="launch_ov_msckf"   default="true"/>
  <arg name="ov_msckf_config"   default="rs_d455"/>  <!-- calibration folder under ov_msckf/../config/ -->
  <arg name="ov_msckf_verbosity" default="INFO"/>
  <arg name="ov_msckf_output" default="log"/>  <!-- roslaunch output mode for ov_msckf: 'screen' or 'log' -->
  
  <!-- Config file -->
  <arg name="config_file" default="$(find hesfm)/config/hesfm_params.yaml"/>
  
  <!-- ===================================================================== -->
  <!-- Intel RealSense D455 Camera -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_camera)">
    <include file="$(find hesfm)/launch/d455_camera.launch">
      <arg name="camera_name" value="$(arg camera_name)"/>
      <arg name="serial_no" value="$(arg serial_no)"/>
    </include>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Semantic Segmentation -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_segmentation)">
    <node name="semantic_segmentation_node" pkg="hesfm" type="semantic_segmentation_node.py"
          output="screen" respawn="false">
      <!-- Input topics -->
      <remap from="color/image_raw" to="$(arg camera_name)/color/image_raw"/>
      <remap from="depth/image_rect_raw" to="$(arg camera_name)/aligned_depth_to_color/image_raw"/>
      <remap from="color/camera_info" to="$(arg camera_name)/color/camera_info"/>
      
      <!-- Parameters -->
      <param name="backend" value="$(arg segmentation_backend)"/>
      <param name="esanet_dataset" value="$(arg esanet_dataset)"/>
      <param name="num_classes" value="$(arg num_classes)"/>
      <param name="input_height" value="480"/>
      <param name="input_width" value="640"/>
      <param name="confidence_threshold" value="0.3"/>

      <!-- Model paths -->
      <param name="dformer_model_path" value="$(find hesfm)/models/dformer_large_sunrgbd.pth"/>
      <param name="esanet_model_path" value="$(find hesfm)/models/esanet_r34_sunrgbd.pth"/>
      <param name="esanet_trt_engine" value="$(find hesfm)/models/esanet_r34_sunrgbd_fp16.engine"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Semantic Point Cloud Generator -->
  <!-- ===================================================================== -->
  
  <node name="semantic_cloud_node" pkg="hesfm" type="semantic_cloud_node"
        output="screen" respawn="false">
    <!-- Input topics -->
    <remap from="color/image_raw" to="$(arg camera_name)/color/image_raw"/>
    <remap from="depth/image_rect_raw" to="$(arg camera_name)/aligned_depth_to_color/image_raw"/>
    <remap from="color/camera_info" to="$(arg camera_name)/color/camera_info"/>
    <remap from="semantic/image" to="semantic_segmentation_node/semantic_image"/>
    
    <!-- Parameters -->
    <param name="downsample_factor" value="$(arg downsample_factor)"/>
    <param name="min_depth" value="0.1"/>
    <param name="max_depth" value="6.0"/>
    <param name="esanet_dataset" value="$(arg esanet_dataset)"/>
    <param name="default_uncertainty" value="0.3"/>
    <param name="queue_size" value="30"/>
  </node>
  
  <!-- ===================================================================== -->
  <!-- HESFM Mapper -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_mapper)">
    <node name="hesfm_mapper_node" pkg="hesfm" type="hesfm_mapper_node"
          output="screen" respawn="false">
      <!-- Load parameters from config file -->
      <rosparam file="$(arg config_file)" command="load"/>
      
      <!-- Override with launch arguments -->
      <param name="map_frame"      value="$(arg map_frame)"/>
      <param name="esanet_dataset" value="$(arg esanet_dataset)"/>
      <param name="resolution"     value="$(arg resolution)"/>
      <param name="map_size_x"     value="$(arg map_size_x)"/>
      <param name="map_size_y"     value="$(arg map_size_y)"/>
      <param name="map_size_z"     value="$(arg map_size_z)"/>
      <param name="num_classes"    value="$(arg num_classes)"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Costmap Generator -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_costmap)">
    <node name="costmap_node" pkg="hesfm" type="costmap_node"
          output="screen" respawn="false">
      <param name="map_frame" value="$(arg map_frame)"/>
      <param name="resolution" value="$(arg resolution)"/>
      <param name="size_x" value="$(arg map_size_x)"/>
      <param name="size_y" value="$(arg map_size_y)"/>
      <param name="height_min" value="0.0"/>
      <param name="height_max" value="0.5"/>
      <param name="inflation_radius" value="0.3"/>
      <param name="publish_rate" value="5.0"/>
      
      <!-- Traversable classes: floor (1), floor_mat (19) -->
      <rosparam param="traversable_classes">[1, 19]</rosparam>
    </node>
  </group>

  <!-- ===================================================================== -->
  <!-- 3D Semantic Costmap Generator -->
  <!-- ===================================================================== -->
  <!-- 
    3D voxel-based semantic costmap that combines:
    - Semantic class-based traversability costs
    - Height-based obstacle filtering  
    - HESFM uncertainty integration
    
    Publishes:
    - /semantic_costmap_3d: 3D visualization (MarkerArray)
    - /semantic_costmap_2d: 2D projection for move_base (OccupancyGrid)
    - /traversability_cloud: Color-coded traversability point cloud
  -->
  
  <group if="$(arg launch_costmap_3d)">
    <node name="semantic_costmap_3d_node" pkg="hesfm" type="semantic_costmap_3d_node"
          output="screen" respawn="true">
      <!-- Input topics -->
      <remap from="semantic_cloud" to="semantic_cloud_node/semantic_cloud"/>
      <remap from="odom" to="odom"/>
      
      <!-- Frame configuration -->
      <param name="map_frame" value="$(arg map_frame)"/>
      <param name="robot_frame" value="$(arg base_frame)"/>
      
      <!-- Voxel grid parameters (Xavier-optimized) -->
      <param name="voxel_size" value="0.1"/>
      <param name="map_size_x" value="15.0"/>
      <param name="map_size_y" value="15.0"/>
      <param name="map_size_z" value="2.5"/>
      
      <!-- Robot parameters -->
      <param name="robot_height" value="0.5"/>
      <param name="robot_radius" value="0.3"/>
      <param name="ground_clearance" value="0.05"/>
      
      <!-- Cost computation -->
      <param name="slope_cost_factor" value="0.5"/>
      <param name="step_cost_factor" value="0.3"/>
      <param name="uncertainty_cost_factor" value="0.2"/>
      <param name="lethal_cost_threshold" value="0.9"/>
      
      <!-- SUN RGB-D: 37 classes -->
      <param name="num_classes" value="$(arg num_classes)"/>
      
      <!-- Publication rate (lower for Xavier) -->
      <param name="publish_rate" value="3.0"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Visualization -->
  <!-- ===================================================================== -->
  
  <group if="$(arg launch_visualization)">
    <node name="visualization_node" pkg="hesfm" type="visualization_node"
          output="screen" respawn="false">
      <param name="num_classes" value="$(arg num_classes)"/>
      <param name="publish_legend" value="true"/>
    </node>
  </group>
  
  <!-- ===================================================================== -->
  <!-- OpenVINS VIO (ov_msckf) -->
  <!-- ===================================================================== -->
  <group if="$(arg launch_ov_msckf)">
    <include file="$(find ov_msckf)/launch/subscribe.launch">
      <arg name="config"      value="$(arg ov_msckf_config)"/>
      <arg name="verbosity"   value="$(arg ov_msckf_verbosity)"/>
      <arg name="output"      value="$(arg ov_msckf_output)"/>
    </include>
    <!-- Bridge: hesfm map frame ↔ ov_msckf world frame -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_global"
          args="0 0 0 0 0 0 imu camera_link "/>
  </group>

  <!-- ===================================================================== -->
  <!-- RViz -->
  <!-- ===================================================================== -->
  
  <group if="$(arg rviz)">
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find hesfm)/rviz/hesfm.rviz"
          output="screen"/>
  </group>
  
  <!-- ===================================================================== -->
  <!-- Static TF (if no robot/odometry) -->
  <!-- ===================================================================== -->
  
  <!-- Static TF fallback: used only when ov_msckf is NOT running.
       When ov_msckf is active it publishes map→global→imu→cam0/cam1 itself. -->
  <group unless="$(arg launch_ov_msckf)">
    <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom"
          args="0 0 0 0 0 0 $(arg map_frame) $(arg odom_frame)"/>
    <node pkg="tf2_ros" type="static_transform_publisher" name="odom_to_base"
          args="0 0 0 0 0 0 $(arg odom_frame) $(arg base_frame)"/>
  </group>
  
</launch>