<?xml version="1.0"?>
<!--
   HESFM — Evidential perception + uncertainty-aware mapping.

   Selectable segmentation model:
     model:=esanet      (default) — ESANet  + F-EDL
     model:=dformerv2              — DFormerv2 + F-EDL

   Pipeline wired up:
      1. <model>_evidential_node              (RGB-D -> label, mu, vacuity)
      2. uncertainty_aware_semantic_cloud_node (-> /hesfm/semantic_cloud)
      3. hesfm_mapper_node                    (BKI update with U-A kernel)
-->
<launch>

  <!-- ===================================================================== -->
  <!--                              Arguments                                -->
  <!-- ===================================================================== -->
  <arg name="model"        default="esanet" doc="esanet | dformerv2"/>
  <arg name="backend"      default="torch"  doc="torch | trt"/>
  <arg name="num_classes"  default="40"/>
  <arg name="flexible"     default="true"/>
  <arg name="device"       default="cuda:0"/>

  <!-- ESANet-specific -->
  <arg name="esanet_checkpoint"  default="$(find hesfm)/checkpoints/esanet_r34_evidential.pth"/>
  <arg name="esanet_engine"      default="$(find hesfm)/checkpoints/esanet_r34_evidential_fp16.engine"/>

  <!-- DFormerv2-specific -->
  <arg name="dformer_backbone"   default="DFormerv2_L"/>
  <arg name="dformer_decoder"    default="MLPDecoder"/>
  <arg name="dformer_embed_dim"  default="512"/>
  <arg name="dformer_checkpoint" default="$(find hesfm)/checkpoints/dformerv2_l_evidential.pth"/>
  <arg name="dformer_engine"     default="$(find hesfm)/checkpoints/dformerv2_l_evidential_fp16.engine"/>
  <arg name="dformer_path"       default=""/>

  <arg name="rgb_topic"    default="/camera/color/image_raw"/>
  <arg name="depth_topic"  default="/camera/aligned_depth_to_color/image_raw"/>
  <arg name="info_topic"   default="/camera/color/camera_info"/>

  <arg name="use_rviz"     default="true"/>

  <!-- ===================================================================== -->
  <!-- 1a) ESANet evidential segmentation                                    -->
  <!-- ===================================================================== -->
  <group if="$(eval arg('model') == 'esanet')">
    <node pkg="hesfm" type="esanet_evidential_node.py"
          name="esanet_evidential_node" output="screen" required="true">
      <rosparam command="load" file="$(find hesfm)/config/evidential_params.yaml"/>
      <param name="backend"      value="$(arg backend)"/>
      <param name="checkpoint"   value="$(arg esanet_checkpoint)"/>
      <param name="engine_path"  value="$(arg esanet_engine)"/>
      <param name="num_classes"  value="$(arg num_classes)"/>
      <param name="flexible"     value="$(arg flexible)"/>
      <param name="device"       value="$(arg device)"/>
      <param name="rgb_topic"    value="$(arg rgb_topic)"/>
      <param name="depth_topic"  value="$(arg depth_topic)"/>
    </node>
  </group>

  <!-- ===================================================================== -->
  <!-- 1b) DFormerv2 evidential segmentation                                 -->
  <!-- ===================================================================== -->
  <group if="$(eval arg('model') == 'dformerv2')">
    <node pkg="hesfm" type="dformerv2_evidential_node.py"
          name="dformerv2_evidential_node" output="screen" required="true">
      <rosparam command="load"
                file="$(find hesfm)/config/dformerv2_evidential_params.yaml"/>
      <param name="backend"           value="$(arg backend)"/>
      <param name="checkpoint"        value="$(arg dformer_checkpoint)"/>
      <param name="engine_path"       value="$(arg dformer_engine)"/>
      <param name="num_classes"       value="$(arg num_classes)"/>
      <param name="flexible"          value="$(arg flexible)"/>
      <param name="device"            value="$(arg device)"/>
      <param name="backbone"          value="$(arg dformer_backbone)"/>
      <param name="decoder"           value="$(arg dformer_decoder)"/>
      <param name="decoder_embed_dim" value="$(arg dformer_embed_dim)"/>
      <param name="dformer_path"      value="$(arg dformer_path)"/>
      <param name="rgb_topic"         value="$(arg rgb_topic)"/>
      <param name="depth_topic"       value="$(arg depth_topic)"/>
    </node>
  </group>

  <!-- ===================================================================== -->
  <!-- 2) Uncertainty-aware semantic point-cloud builder                      -->
  <!-- ===================================================================== -->
  <node pkg="hesfm" type="uncertainty_aware_semantic_cloud_node.py"
        name="uncertainty_aware_semantic_cloud_node" output="screen">
    <rosparam command="load" file="$(find hesfm)/config/uncertainty_aware_bki.yaml"/>
    <param name="num_classes"        value="$(arg num_classes)"/>
    <param name="depth_topic"        value="$(arg depth_topic)"/>
    <param name="camera_info_topic"  value="$(arg info_topic)"/>
  </node>

  <!-- ===================================================================== -->
  <!-- 3) HESFM core mapper (consumes /hesfm/semantic_cloud)                  -->
  <!-- ===================================================================== -->
  <node pkg="hesfm" type="hesfm_mapper_node" name="hesfm_mapper_node"
        output="screen">
    <rosparam command="load" file="$(find hesfm)/config/uncertainty_aware_bki.yaml"/>
    <rosparam command="load" file="$(find hesfm)/config/hesfm_params.yaml"/>
  </node>

  <!-- ===================================================================== -->
  <!-- 4) RViz                                                                -->
  <!-- ===================================================================== -->
  <group if="$(arg use_rviz)">
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find hesfm)/rviz/hesfm.rviz"/>
  </group>

</launch>
